{"id":"migration-232","category":"db_zero_downtime","difficulty":"expert","title":"Adding query result caching","current_state":{"description":"Repeated identical queries","code_sample":"--","business_drivers":"Cost"},"target_state":{"description":"Redis cache","code_sample":"--","benefits":"Reduced DB load"},"anti_patterns_to_avoid":["Cache everything","No invalidation","Stale data tolerated"],"migration_strategy":["Phase 1: Identify hot read paths","Phase 2: Cache with TTL","Phase 3: Invalidation hooks","Phase 4: Monitor"],"reasoning":"Cache hot reads; invalidate on write.","rollback_procedure":"Disable cache","feature_flag_strategy":"Per-query","telemetry_requirements":"Hit rate","solution":"async function getUser(id){\n  const cached = await redis.get(`user:${id}`);\n  if (cached) return JSON.parse(cached);\n  const user = await pool.query('SELECT * FROM users WHERE id=$1', [id]);\n  await redis.setEx(`user:${id}`, 60, JSON.stringify(user.rows[0]));\n  return user.rows[0];\n}\n\n// invalidate on update\nasync function updateUser(id, patch) {\n  await pool.query('UPDATE users ...');\n  await redis.del(`user:${id}`);\n}","duration_estimate":{"engineering_days":5,"calendar_weeks":2,"key_milestones":["Cache","Invalidation"]},"what_breaks_naive_approach":"Stale data."}
