{"id":"migration-224","category":"db_zero_downtime","difficulty":"expert","title":"Migrating from auth.users to public.users","current_state":{"description":"Supabase auth.users","code_sample":"--","business_drivers":"Custom fields"},"target_state":{"description":"public.profiles linked","code_sample":"--","benefits":"Extensible"},"anti_patterns_to_avoid":["Modify auth.users","Skip trigger sync","Lose auth integration"],"migration_strategy":["Phase 1: public.profiles","Phase 2: Trigger on auth.users insert","Phase 3: App reads profile"],"reasoning":"auth.* is platform-managed; mirror to your own table.","rollback_procedure":"Per-trigger","feature_flag_strategy":"N/A","telemetry_requirements":"Sync gaps","solution":"CREATE TABLE public.profiles (id UUID PRIMARY KEY REFERENCES auth.users(id), display_name TEXT);\n\nCREATE FUNCTION on_auth_user_created() RETURNS trigger AS $$\nBEGIN\n  INSERT INTO public.profiles(id, display_name) VALUES (NEW.id, COALESCE(NEW.raw_user_meta_data->>'name', 'New User'));\n  RETURN NEW;\nEND;\n$$ LANGUAGE plpgsql SECURITY DEFINER;\nCREATE TRIGGER on_auth_user_created AFTER INSERT ON auth.users FOR EACH ROW EXECUTE FUNCTION on_auth_user_created();","duration_estimate":{"engineering_days":3,"calendar_weeks":1,"key_milestones":["Table","Trigger"]},"what_breaks_naive_approach":"Modify auth.users: platform breaks."}
