{"id":"migration-213","category":"data_migration","difficulty":"expert","title":"Cleaning up duplicate rows","current_state":{"description":"emails table has dupes","code_sample":"--","business_drivers":"Constraint addition"},"target_state":{"description":"Unique","code_sample":"--","benefits":"Integrity"},"anti_patterns_to_avoid":["DELETE without backup","No FK fix","Skip merging children"],"migration_strategy":["Phase 1: Identify dupes","Phase 2: Pick canonical","Phase 3: Re-point children","Phase 4: Delete extras","Phase 5: Add UNIQUE"],"reasoning":"Merge carefully — preserve relationships.","rollback_procedure":"Backup restore","feature_flag_strategy":"N/A","telemetry_requirements":"Dupes removed","solution":"-- pick MIN(id) per email as canonical\nWITH dupes AS (\n  SELECT email, MIN(id) AS keep_id, array_agg(id) AS all_ids\n  FROM users GROUP BY email HAVING count(*) > 1\n)\n-- re-point children\nUPDATE orders o SET user_id = d.keep_id FROM dupes d WHERE o.user_id = ANY(d.all_ids) AND o.user_id != d.keep_id;\n-- delete extras\nDELETE FROM users WHERE id IN (SELECT unnest(all_ids) FROM dupes) AND id NOT IN (SELECT keep_id FROM dupes);\n-- add unique\nALTER TABLE users ADD CONSTRAINT email_unique UNIQUE (email);","duration_estimate":{"engineering_days":3,"calendar_weeks":1,"key_milestones":["Merged","Unique"]},"what_breaks_naive_approach":"FK violations."}
