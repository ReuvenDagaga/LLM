{"id":"e2e-275","category":"full_stack_verification","difficulty":"expert","title":"Adding 2FA backup codes: generate + verify + invalidate","scenario_context":"User loses phone. Backup codes. Generate at enroll. Each single-use.","verification_chain":["Layer 1: codes hashed","Layer 3: verify + invalidate","Layer 8: display once","Layer 10: backup_code_used_total"],"anti_patterns_to_avoid":["Plain text storage","Re-displayable","Reuse","No regenerate"],"what_breaks_naive_approach":"User loses codes — locked out.","reasoning":"Generate 10 codes, hash, store. Show once. On use, verify hash, mark used. Regenerate option invalidates all.","shared_schema":"// N/A","backend_solution":"// server/services/backupCodesService.ts\nimport bcrypt from 'bcrypt';\nexport const backupCodesService = {\n  async generate(userId: string) {\n    const codes = Array.from({ length: 10 }, () => crypto.randomBytes(5).toString('hex'));\n    await BackupCodeModel.deleteMany({ userId });\n    await BackupCodeModel.insertMany(codes.map(c => ({ userId, codeHash: bcrypt.hashSync(c, 10), used: false })));\n    return codes;\n  },\n  async verify(userId: string, code: string) {\n    const stored = await BackupCodeModel.find({ userId, used: false });\n    for (const s of stored) if (bcrypt.compareSync(code, s.codeHash)) { s.used = true; await s.save(); return true; }\n    return false;\n  }\n};","frontend_solution":"// display codes once, download as txt option","error_handling_strategy":{"server_errors":"401 invalid","client_error_mapping":"Show error","user_facing_messages":"'Code invalid or used'","recovery_actions":"Contact admin","telemetry":"backup usage"},"edge_cases_addressed":["Lost all codes","Admin reset","Codes exhausted — regen forced","Display once + download","Audit","Locale","Print"],"test_strategy":"Verify + invalidate","observability_hooks":"Backup usage signal","what_distinguishes_senior_thinking":"1) Hashed. 2) Single-use. 3) Regen invalidates all."}
