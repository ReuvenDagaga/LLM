ג{"id":"review-151","category":"hidden_rerender_bugs","difficulty":"expert","scenario":"Array.from in render.","submitter_context":"PR: 'Render N skeleton items.'","code_under_review":"function Skeleton({ count }: { count: number }) {\n  return (\n    <ul>\n      {Array.from({ length: count }).map((_, i) => (\n        <li key={i}><div className=\"animate-pulse h-4 bg-gray-200\" /></li>\n      ))}\n    </ul>\n  );\n}","looks_reasonable_because":["Array.from","Index key","Works"],"review_summary":"Index keys cause subtle issues if count changes. For skeleton specifically OK since items identical.","issues_found":[{"issue_number":1,"severity":"minor","location":"key={i}","title":"Index keys (case-specific OK here)","explanation":"For static identical skeleton items, index keys are fine. For dynamic lists, index keys cause incorrect reconciliation.","root_cause":"Index keys generally bad, OK here","fix":"None for this case","verification":"N/A"}],"issues_that_arent_issues":"Skeleton pattern fine.","broader_pattern":"Index keys: OK for static lists with no add/remove, problematic for dynamic.","fixed_code":"// Current is acceptable. For clarity:\nfunction Skeleton({ count }: { count: number }) {\n  return (\n    <ul aria-busy=\"true\" aria-live=\"polite\">\n      {Array.from({ length: count }, (_, i) => (\n        <li key={i}>\n          <div className=\"animate-pulse h-4 bg-gray-200 rounded\" aria-hidden=\"true\" />\n        </li>\n      ))}\n      <span className=\"sr-only\">Loading</span>\n    </ul>\n  );\n}","what_makes_this_review_senior":"Knowing when index keys are OK; aria-busy for SR loading state."}
{"id":"review-152","category":"memory_leaks_in_hooks","difficulty":"expert","scenario":"Listener on ref.","submitter_context":"PR: 'Click outside hook.'","code_under_review":"function useClickOutside(callback: () => void) {\n  const ref = useRef<HTMLDivElement>(null);\n  useEffect(() => {\n    const handler = (e: MouseEvent) => {\n      if (ref.current && !ref.current.contains(e.target as Node)) callback();\n    };\n    document.addEventListener('mousedown', handler);\n    return () => document.removeEventListener('mousedown', handler);\n  }, [callback]);\n  return ref;\n}","looks_reasonable_because":["Click outside","Cleanup","Works"],"review_summary":"callback in deps recreates handler. Plus mousedown vs click semantics.","issues_found":[{"issue_number":1,"severity":"major","location":"callback in deps","title":"Re-subscribes each render","explanation":"Inline callback recreates. addEventListener / removeEventListener each render.","root_cause":"Callback in deps","fix":"Ref pattern","verification":"Profiler"},{"issue_number":2,"severity":"minor","location":"mousedown","title":"mousedown vs click","explanation":"mousedown fires before click. Closing on mousedown may prevent click on inside element.","root_cause":"Event timing","fix":"Verify behavior","verification":"Test inside clicks"}],"issues_that_arent_issues":"Pattern itself OK.","broader_pattern":"Callback in deps; mousedown semantics for menus.","fixed_code":"function useClickOutside<T extends HTMLElement>(callback: () => void) {\n  const ref = useRef<T>(null);\n  const callbackRef = useRef(callback);\n  useEffect(() => { callbackRef.current = callback; }, [callback]);\n  \n  useEffect(() => {\n    const handler = (e: MouseEvent) => {\n      if (ref.current && !ref.current.contains(e.target as Node)) {\n        callbackRef.current();\n      }\n    };\n    document.addEventListener('mousedown', handler);\n    return () => document.removeEventListener('mousedown', handler);\n  }, []);\n  \n  return ref;\n}","what_makes_this_review_senior":"Callback ref pattern; mousedown timing awareness."}
{"id":"review-153","category":"race_conditions_in_async","difficulty":"expert","scenario":"Multiple mutations.","submitter_context":"PR: 'Save name + email separately.'","code_under_review":"async function saveBoth(name: string, email: string) {\n  await fetch('/api/name', { method: 'PUT', body: name });\n  await fetch('/api/email', { method: 'PUT', body: email });\n  toast.success('Saved');\n}","looks_reasonable_because":["Sequential","Both await","Success toast"],"review_summary":"Partial failure leaves inconsistent state. Plus serial when could be parallel.","issues_found":[{"issue_number":1,"severity":"critical","location":"sequential","title":"Partial failure inconsistency","explanation":"Name saves, email fails. User thinks neither saved (error shown), but name is.","root_cause":"No atomic","fix":"Transaction endpoint or roll back","verification":"Block second"},{"issue_number":2,"severity":"minor","location":"sequential","title":"Slow","explanation":"Could parallel.","root_cause":"Sequential","fix":"Promise.all","verification":"Network tab"}],"issues_that_arent_issues":"PUT semantics OK per field.","broader_pattern":"Multi-step writes need atomicity (single endpoint or compensating actions).","fixed_code":"async function saveProfile(profile: { name: string; email: string }) {\n  // Single endpoint with atomic update\n  const r = await fetch('/api/profile', {\n    method: 'PUT',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(profile)\n  });\n  if (!r.ok) throw new Error('Save failed');\n  toast.success('Saved');\n}\n// If atomic endpoint not possible, design compensating actions:\n// 1. Save name\n// 2. Save email\n// 3. If email fails, revert name (or queue for retry)","what_makes_this_review_senior":"Atomicity in multi-step writes."}
{"id":"review-154","category":"typescript_false_confidence","difficulty":"expert","scenario":"Generic function with returns.","submitter_context":"PR: 'Generic find.'","code_under_review":"function findById<T>(items: T[], id: string): T {\n  return items.find(i => (i as any).id === id);\n}","looks_reasonable_because":["Generic","Type-safe return","Works"],"review_summary":"Find returns T | undefined. Return type T is wrong. Plus any cast loses type.","issues_found":[{"issue_number":1,"severity":"critical","location":"return T","title":"Lies about undefined","explanation":"find can return undefined. T return type is incorrect.","root_cause":"Wrong type","fix":"T | undefined","verification":"Pass non-matching id"},{"issue_number":2,"severity":"major","location":"as any","title":"any cast","explanation":"T doesn't constrain id. Cast to any.","root_cause":"No constraint","fix":"T extends {id: string}","verification":"TS"}],"issues_that_arent_issues":"Generic concept OK.","broader_pattern":"Generic constraints + accurate return types.","fixed_code":"function findById<T extends { id: string }>(items: T[], id: string): T | undefined {\n  return items.find(i => i.id === id);\n}\n\nconst user = findById(users, 'u1');\nif (user) {\n  // narrowed to User\n}","what_makes_this_review_senior":"find return type union; T extends constraint."}
{"id":"review-155","category":"accessibility_violations","difficulty":"expert","scenario":"Sticky tab focus.","submitter_context":"PR: 'Tabs.'","code_under_review":"function Tabs({ items }: Props) {\n  const [active, setActive] = useState(0);\n  return (\n    <>\n      <div role=\"tablist\">\n        {items.map((item, i) => (\n          <button\n            key={i}\n            role=\"tab\"\n            aria-selected={active === i}\n            onClick={() => setActive(i)}\n          >\n            {item.label}\n          </button>\n        ))}\n      </div>\n      <div role=\"tabpanel\">{items[active]?.content}</div>\n    </>\n  );\n}","looks_reasonable_because":["Roles","aria-selected","Works"],"review_summary":"Missing aria-controls, tab id, panel id. No arrow key nav. Tab focus order wrong.","issues_found":[{"issue_number":1,"severity":"critical","location":"No arrow keys","title":"Arrow keys don't move tabs","explanation":"Standard tabs use arrow keys to switch tabs. Currently Tab moves into panel.","root_cause":"No key handler","fix":"onKeyDown","verification":"Arrow keys"},{"issue_number":2,"severity":"major","location":"No aria-controls/labelledby","title":"Tab-panel association missing","explanation":"SR doesn't know which panel goes with which tab.","root_cause":"Missing","fix":"aria-controls + labelledby","verification":"SR"},{"issue_number":3,"severity":"major","location":"All buttons tabIndex 0","title":"Wrong tab focus order","explanation":"All tabs focusable via Tab key. Standard: only active tab in tab order. Inactive use arrow keys.","root_cause":"No tabIndex management","fix":"tabIndex={active === i ? 0 : -1}","verification":"Tab through"}],"issues_that_arent_issues":"role usage OK.","broader_pattern":"Tab pattern: roving tabindex + arrow keys + aria-controls.","fixed_code":"function Tabs({ items, id }: { items: Item[]; id: string }) {\n  const [active, setActive] = useState(0);\n  const tabRefs = useRef<(HTMLButtonElement | null)[]>([]);\n  \n  const onKeyDown = (e: React.KeyboardEvent, i: number) => {\n    if (e.key === 'ArrowRight') {\n      const next = (i + 1) % items.length;\n      setActive(next);\n      tabRefs.current[next]?.focus();\n    } else if (e.key === 'ArrowLeft') {\n      const next = (i - 1 + items.length) % items.length;\n      setActive(next);\n      tabRefs.current[next]?.focus();\n    }\n  };\n  \n  return (\n    <>\n      <div role=\"tablist\">\n        {items.map((item, i) => (\n          <button\n            key={item.id}\n            ref={(el) => { tabRefs.current[i] = el; }}\n            role=\"tab\"\n            id={`${id}-tab-${i}`}\n            aria-selected={active === i}\n            aria-controls={`${id}-panel-${i}`}\n            tabIndex={active === i ? 0 : -1}\n            onClick={() => setActive(i)}\n            onKeyDown={(e) => onKeyDown(e, i)}\n          >\n            {item.label}\n          </button>\n        ))}\n      </div>\n      <div role=\"tabpanel\" id={`${id}-panel-${active}`} aria-labelledby={`${id}-tab-${active}`} tabIndex={0}>\n        {items[active]?.content}\n      </div>\n    </>\n  );\n}\n// Or use Radix Tabs which handles all this","what_makes_this_review_senior":"Full WAI-ARIA tabs pattern; roving tabindex."}
{"id":"review-156","category":"state_management_misuse","difficulty":"expert","scenario":"Action creator returning new state.","submitter_context":"PR: 'Cart slice.'","code_under_review":"const useCart = create((set) => ({\n  items: [],\n  add: (item) => {\n    const state = useCart.getState();\n    state.items.push(item);\n    set({ items: state.items });\n  }\n}));","looks_reasonable_because":["Add to cart","Set state","Works"],"review_summary":"Mutates state directly + sets same reference = no re-render.","issues_found":[{"issue_number":1,"severity":"critical","location":"state.items.push","title":"Mutating state","explanation":"Zustand requires immutable updates. push mutates the array reference.","root_cause":"Direct mutation","fix":"Spread to new array","verification":"Add item, check re-render"},{"issue_number":2,"severity":"major","location":"useCart.getState()","title":"Should use set callback","explanation":"set(s => ...) gives latest state.","root_cause":"getState in action","fix":"set callback","verification":"Refactor"}],"issues_that_arent_issues":"Action structure OK.","broader_pattern":"Immutable updates in state libs.","fixed_code":"const useCart = create<CartStore>((set) => ({\n  items: [],\n  add: (item) => set(s => ({ items: [...s.items, item] })),\n  remove: (id) => set(s => ({ items: s.items.filter(i => i.id !== id) }))\n}));\n// Or with Immer for nested updates:\nimport { create } from 'zustand';\nimport { immer } from 'zustand/middleware/immer';\n\nconst useCart = create<CartStore>()(immer((set) => ({\n  items: [],\n  add: (item) => set(s => { s.items.push(item); })  // Immer allows mutation syntax\n})));","what_makes_this_review_senior":"Immutability in state libs; Immer middleware option."}
{"id":"review-157","category":"form_handling_disasters","difficulty":"expert","scenario":"File upload validation.","submitter_context":"PR: 'Upload profile pic.'","code_under_review":"function Upload() {\n  const onFile = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (file) {\n      const fd = new FormData();\n      fd.append('file', file);\n      fetch('/api/upload', { method: 'POST', body: fd });\n    }\n  };\n  return <input type=\"file\" onChange={onFile} accept=\"image/*\" />;\n}","looks_reasonable_because":["accept hint","FormData","Works"],"review_summary":"accept is hint only - users can bypass. No size, type validation, error handling.","issues_found":[{"issue_number":1,"severity":"critical","location":"accept only","title":"Client-side accept bypassable","explanation":"accept attribute filters file picker. User can still drag/drop or save-as. Server must validate.","root_cause":"Trust client","fix":"Client + server validation","verification":"Save .exe as .png"},{"issue_number":2,"severity":"major","location":"no size check","title":"Huge files","explanation":"Upload 1GB file = bad.","root_cause":"No size","fix":"Size check","verification":"Large file"},{"issue_number":3,"severity":"major","location":"no error","title":"Upload failure silent","explanation":"No status feedback.","root_cause":"No error","fix":"Status state","verification":"Block network"},{"issue_number":4,"severity":"minor","location":"no progress","title":"No upload progress","explanation":"User wonders if uploading.","root_cause":"Plain fetch","fix":"XHR for progress","verification":"Slow network"}],"issues_that_arent_issues":"FormData usage OK.","broader_pattern":"File uploads: client validation + server validation + progress + error.","fixed_code":"function Upload() {\n  const [progress, setProgress] = useState(0);\n  const [error, setError] = useState<string | null>(null);\n  \n  const onFile = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (!file) return;\n    \n    // Client validation\n    if (!file.type.startsWith('image/')) {\n      setError('Image only');\n      return;\n    }\n    if (file.size > 5 * 1024 * 1024) {\n      setError('Max 5MB');\n      return;\n    }\n    setError(null);\n    \n    // Upload with progress\n    const fd = new FormData();\n    fd.append('file', file);\n    const xhr = new XMLHttpRequest();\n    xhr.upload.onprogress = (e) => {\n      if (e.lengthComputable) setProgress(Math.round((e.loaded / e.total) * 100));\n    };\n    xhr.onload = () => {\n      if (xhr.status >= 200 && xhr.status < 300) {\n        setProgress(100);\n      } else {\n        setError('Upload failed');\n      }\n    };\n    xhr.onerror = () => setError('Network error');\n    xhr.open('POST', '/api/upload');\n    xhr.send(fd);\n  };\n  \n  return (\n    <>\n      <input type=\"file\" accept=\"image/*\" onChange={onFile} />\n      {progress > 0 && progress < 100 && <progress value={progress} max={100} />}\n      {error && <span role=\"alert\">{error}</span>}\n    </>\n  );\n}","what_makes_this_review_senior":"Full file upload pattern: client validate, server validate, progress, error."}
{"id":"review-158","category":"animation_performance_hits","difficulty":"expert","scenario":"Loading spinner animation.","submitter_context":"PR: 'Spinner.'","code_under_review":"function Spinner() {\n  const [angle, setAngle] = useState(0);\n  useEffect(() => {\n    const id = setInterval(() => setAngle(a => a + 5), 16);\n    return () => clearInterval(id);\n  }, []);\n  return <div style={{ transform: `rotate(${angle}deg)` }}>⟳</div>;\n}","looks_reasonable_because":["Rotation","Cleanup","Works"],"review_summary":"JS-driven rotation. Each tick = React re-render. CSS animation is one line and runs on compositor.","issues_found":[{"issue_number":1,"severity":"major","location":"JS rotation","title":"React re-renders 60 times/sec","explanation":"setState 60Hz = 60 React renders. CSS animation: 0 React renders, compositor handles.","root_cause":"JS animation for simple rotation","fix":"CSS animation","verification":"Profiler"}],"issues_that_arent_issues":"Spinner concept OK.","broader_pattern":"CSS for simple animations.","fixed_code":"function Spinner() {\n  return <div className=\"animate-spin\">⟳</div>;\n}\n\n/* Tailwind has animate-spin built-in: */\n/* @keyframes spin { to { transform: rotate(360deg); } } */\n/* .animate-spin { animation: spin 1s linear infinite; } */","what_makes_this_review_senior":"CSS for trivial animations; React re-render cost."}
{"id":"review-159","category":"bundle_size_bloat","difficulty":"expert","scenario":"Chart library imports.","submitter_context":"PR: 'Add dashboard charts.'","code_under_review":"import * as d3 from 'd3';\n\nfunction Chart({ data }: { data: any[] }) {\n  const scale = d3.scaleLinear().domain([0, 100]).range([0, 200]);\n  return <svg>{/* D3 chart */}</svg>;\n}","looks_reasonable_because":["D3","Comprehensive","Works"],"review_summary":"`import * as d3` imports ALL of D3 (~250KB). For one scale function.","issues_found":[{"issue_number":1,"severity":"critical","location":"import * as d3","title":"Full D3","explanation":"250KB for one function.","root_cause":"Star","fix":"d3-scale only","verification":"Bundle"}],"issues_that_arent_issues":"D3 for chart OK if needed.","broader_pattern":"D3 modules are individually publishable. Use submodules.","fixed_code":"import { scaleLinear } from 'd3-scale';\n\nfunction Chart({ data }: { data: ChartDatum[] }) {\n  const scale = scaleLinear().domain([0, 100]).range([0, 200]);\n  return <svg>{/* */}</svg>;\n}\n// ~5KB vs 250KB","what_makes_this_review_senior":"D3 sub-packages; named imports."}
{"id":"review-160","category":"error_boundary_failures","difficulty":"expert","scenario":"ErrorBoundary fallback action.","submitter_context":"PR: 'Error UI with retry.'","code_under_review":"class ErrorBoundary extends React.Component {\n  state = { hasError: false };\n  static getDerivedStateFromError() { return { hasError: true }; }\n  render() {\n    if (this.state.hasError) {\n      return (\n        <div>\n          Error\n          <button onClick={() => window.location.reload()}>Retry</button>\n        </div>\n      );\n    }\n    return this.props.children;\n  }\n}","looks_reasonable_because":["Retry button","Reload","Works"],"review_summary":"Reload is heavy. Should reset boundary state. Loses unrelated state.","issues_found":[{"issue_number":1,"severity":"major","location":"window.location.reload","title":"Heavy reset","explanation":"Reload loses all client state. Just reset boundary.","root_cause":"Wrong reset","fix":"setState hasError false","verification":"Click retry"},{"issue_number":2,"severity":"minor","location":"No reset on prop change","title":"Stuck on error after route change","explanation":"Navigate to different route, still error.","root_cause":"No resetKeys","fix":"resetKeys","verification":"Navigate"}],"issues_that_arent_issues":"Error UI OK.","broader_pattern":"ErrorBoundary should reset state, not reload page.","fixed_code":"// Use react-error-boundary\nimport { ErrorBoundary as REB } from 'react-error-boundary';\nimport { useLocation } from 'react-router-dom';\n\nfunction Fallback({ resetErrorBoundary }: { resetErrorBoundary: () => void }) {\n  return (\n    <div role=\"alert\">\n      <p>Something went wrong</p>\n      <button onClick={resetErrorBoundary}>Try again</button>\n    </div>\n  );\n}\n\nexport function ErrorBoundary({ children }: { children: ReactNode }) {\n  const location = useLocation();\n  return (\n    <REB FallbackComponent={Fallback} resetKeys={[location.pathname]}>\n      {children}\n    </REB>\n  );\n}","what_makes_this_review_senior":"resetErrorBoundary vs reload; resetKeys for auto-reset."}
{"id":"review-161","category":"effect_dependency_bugs","difficulty":"expert","scenario":"Effect chain.","submitter_context":"PR: 'Two effects coordinating.'","code_under_review":"function Component({ userId }: { userId: string }) {\n  const [user, setUser] = useState<User | null>(null);\n  const [posts, setPosts] = useState<Post[]>([]);\n  \n  useEffect(() => {\n    fetch(`/api/users/${userId}`).then(r => r.json()).then(setUser);\n  }, [userId]);\n  \n  useEffect(() => {\n    if (user) {\n      fetch(`/api/users/${user.id}/posts`).then(r => r.json()).then(setPosts);\n    }\n  }, [user]);\n  \n  return <></>;\n}","looks_reasonable_because":["Chain","Conditional","Type-safe"],"review_summary":"Effect chain: user → posts. Waterfall. Plus user reference triggers refetch.","issues_found":[{"issue_number":1,"severity":"major","location":"effect chain","title":"Waterfall","explanation":"User fetches, then posts. Sequential when could be parallel.","root_cause":"Chained effects","fix":"Parallel queries","verification":"Network waterfall"},{"issue_number":2,"severity":"major","location":"[user] dep","title":"Refetches on every user object change","explanation":"User refetches, new reference, posts refetch even if user.id unchanged.","root_cause":"Object dep","fix":"user?.id dep","verification":"Profile"},{"issue_number":3,"severity":"major","location":"no cancellation","title":"Race","explanation":"Standard","root_cause":"Standard","fix":"AbortController","verification":"Standard"}],"issues_that_arent_issues":"Concept of fetching related data OK.","broader_pattern":"Avoid effect chains. React Query handles dependent queries.","fixed_code":"function Component({ userId }: { userId: string }) {\n  const { data: user } = useQuery({\n    queryKey: ['user', userId],\n    queryFn: () => fetch(`/api/users/${userId}`).then(r => r.json())\n  });\n  \n  const { data: posts = [] } = useQuery({\n    queryKey: ['user', userId, 'posts'],\n    queryFn: () => fetch(`/api/users/${userId}/posts`).then(r => r.json()),\n    enabled: !!user  // wait for user to exist before fetching posts\n  });\n  \n  return <></>;\n}\n\n// Or better, fetch in parallel if user object isn't needed for posts request:\nconst userQuery = useQuery({ queryKey: ['user', userId], queryFn: ... });\nconst postsQuery = useQuery({ queryKey: ['user', userId, 'posts'], queryFn: ... });\n// Both fire immediately","what_makes_this_review_senior":"React Query enabled flag for dependent queries; parallel where possible."}
{"id":"review-162","category":"component_architecture_smells","difficulty":"expert","scenario":"Component receiving 12 props.","submitter_context":"PR: 'Configurable Card.'","code_under_review":"function Card({\n  title, description, imageUrl, imageAlt, onClick, onShare, onLike, onDelete,\n  variant, size, shadow, border, isOwner, currentUser, createdAt\n}: Props) {\n  // ... renders complex Card\n}","looks_reasonable_because":["Type-safe","All props typed","Reusable"],"review_summary":"12+ props mixing data, callbacks, variants. Should be composed.","issues_found":[{"issue_number":1,"severity":"major","location":"12 props","title":"God component","explanation":"Card with that many responsibilities = unwieldy.","root_cause":"Too many concerns","fix":"Compound or children","verification":"Count props"}],"issues_that_arent_issues":"Card concept fine.","broader_pattern":"Many props = compound components or children.","fixed_code":"// Compound or children-based:\nfunction Card({ children, variant = 'default', className }: { children: ReactNode; variant?: 'default' | 'elevated'; className?: string }) {\n  return <article className={cn('card', variant, className)}>{children}</article>;\n}\nCard.Header = ({ children }: { children: ReactNode }) => <header>{children}</header>;\nCard.Body = ({ children }: { children: ReactNode }) => <div>{children}</div>;\nCard.Actions = ({ children }: { children: ReactNode }) => <footer>{children}</footer>;\n\n// Usage:\n<Card>\n  <Card.Header>\n    <img src={imageUrl} alt={imageAlt} />\n    <h3>{title}</h3>\n  </Card.Header>\n  <Card.Body>{description}</Card.Body>\n  <Card.Actions>\n    <button onClick={onShare}>Share</button>\n    <button onClick={onLike}>Like</button>\n    {isOwner && <button onClick={onDelete}>Delete</button>}\n  </Card.Actions>\n</Card>","what_makes_this_review_senior":"Compound components for variant-heavy UI."}
{"id":"review-163","category":"security_issues_in_frontend","difficulty":"expert","scenario":"Token in URL.","submitter_context":"PR: 'Magic link auth.'","code_under_review":"function MagicLinkVerify() {\n  const [searchParams] = useSearchParams();\n  const token = searchParams.get('token');\n  \n  useEffect(() => {\n    if (token) {\n      fetch('/api/auth/verify', {\n        method: 'POST',\n        body: JSON.stringify({ token })\n      });\n    }\n  }, [token]);\n  \n  return <div>Verifying...</div>;\n}","looks_reasonable_because":["Token from URL","Verify","Pattern"],"review_summary":"Token stays in URL = leaked to logs, history, third-party scripts. Plus no error handling.","issues_found":[{"issue_number":1,"severity":"critical","location":"token in URL","title":"Token leakage","explanation":"URL contains token: visible to history, referer headers, server logs, browser extensions.","root_cause":"Token in URL","fix":"Use immediately + replaceState to remove","verification":"Check history"},{"issue_number":2,"severity":"major","location":"No error","title":"Failed verify silent","explanation":"User stuck on 'verifying' if fails.","root_cause":"No error","fix":"Error state","verification":"Bad token"},{"issue_number":3,"severity":"minor","location":"No content-type","title":"JSON without header","explanation":"Server may misparse","root_cause":"Missing","fix":"Header","verification":"Server"}],"issues_that_arent_issues":"Magic link concept OK.","broader_pattern":"Tokens in URLs: use once, scrub from history.","fixed_code":"function MagicLinkVerify() {\n  const [searchParams] = useSearchParams();\n  const navigate = useNavigate();\n  const [error, setError] = useState<string | null>(null);\n  \n  useEffect(() => {\n    const token = searchParams.get('token');\n    if (!token) return;\n    \n    // Scrub token from URL immediately\n    window.history.replaceState({}, '', '/verify');\n    \n    (async () => {\n      try {\n        const r = await fetch('/api/auth/verify', {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify({ token }),\n          credentials: 'include'\n        });\n        if (!r.ok) throw new Error('Verification failed');\n        navigate('/dashboard');\n      } catch (e) {\n        setError(e instanceof Error ? e.message : 'Failed');\n      }\n    })();\n  }, []);  // run once on mount\n  \n  if (error) return <div role=\"alert\">{error}</div>;\n  return <div>Verifying...</div>;\n}","what_makes_this_review_senior":"Token leakage via URL; replaceState to scrub."}
{"id":"review-164","category":"hydration_mismatches","difficulty":"expert","scenario":"Server-rendered counter.","submitter_context":"PR: 'Item count.'","code_under_review":"function ItemList({ items }: { items: Item[] }) {\n  return (\n    <>\n      <p>{items.length} items found</p>\n      {items.length === 0 && <EmptyState />}\n      {items.map(i => <Item key={i.id} {...i} />)}\n    </>\n  );\n}","looks_reasonable_because":["Length","Empty state","Render items"],"review_summary":"This is fine. Looks reasonable IS reasonable. No issues.","issues_found":[{"issue_number":1,"severity":"nitpick","location":"plural i18n","title":"'1 items' instead of '1 item'","explanation":"Pluralization not handled.","root_cause":"Hardcoded","fix":"Intl.PluralRules or i18n","verification":"items.length === 1"}],"issues_that_arent_issues":"Render pattern fully fine.","broader_pattern":"Pluralization for i18n.","fixed_code":"function ItemList({ items }: { items: Item[] }) {\n  const fmt = new Intl.PluralRules('en');\n  const count = items.length;\n  const label = fmt.select(count) === 'one' ? '1 item' : `${count} items`;\n  return (\n    <>\n      <p>{label} found</p>\n      {count === 0 ? <EmptyState /> : items.map(i => <Item key={i.id} {...i} />)}\n    </>\n  );\n}","what_makes_this_review_senior":"Pluralization is i18n concern even in English."}
{"id":"review-165","category":"production_only_bugs","difficulty":"expert","scenario":"Service worker registration.","submitter_context":"PR: 'Register service worker.'","code_under_review":"if ('serviceWorker' in navigator) {\n  navigator.serviceWorker.register('/sw.js');\n}","looks_reasonable_because":["SW registration","Feature check","Works"],"review_summary":"Runs at import time = before page loads. No error handling. No version handling.","issues_found":[{"issue_number":1,"severity":"major","location":"top-level","title":"Runs too early","explanation":"Should run after page load.","root_cause":"Top-level","fix":"window.load event","verification":"Browser tools"},{"issue_number":2,"severity":"major","location":"No error","title":"Registration failure silent","explanation":"SW errors lost.","root_cause":"No catch","fix":".catch","verification":"Block sw.js"},{"issue_number":3,"severity":"minor","location":"No version","title":"Old SW persists","explanation":"After deploy, old SW serves stale assets.","root_cause":"No version","fix":"skipWaiting + clientsClaim","verification":"Deploy"}],"issues_that_arent_issues":"Feature check OK.","broader_pattern":"SW registration timing + versioning.","fixed_code":"if ('serviceWorker' in navigator) {\n  window.addEventListener('load', async () => {\n    try {\n      const registration = await navigator.serviceWorker.register('/sw.js');\n      registration.addEventListener('updatefound', () => {\n        const newWorker = registration.installing;\n        newWorker?.addEventListener('statechange', () => {\n          if (newWorker.state === 'activated' && navigator.serviceWorker.controller) {\n            // New SW active. Prompt user to reload.\n            if (confirm('A new version is available. Reload?')) {\n              window.location.reload();\n            }\n          }\n        });\n      });\n    } catch (error) {\n      telemetry.error('sw_registration_failed', { error });\n    }\n  });\n}","what_makes_this_review_senior":"SW lifecycle; update prompts; error reporting."}
{"id":"review-166","category":"hidden_rerender_bugs","difficulty":"expert","scenario":"Memoized child with object prop.","submitter_context":"PR: 'Card list with memo.'","code_under_review":"function CardList({ items, theme }: Props) {\n  return (\n    <ul>\n      {items.map(item => (\n        <CardMemo key={item.id} item={item} style={{ background: theme.bg }} />\n      ))}\n    </ul>\n  );\n}\nconst CardMemo = memo(({ item, style }: { item: Item; style: object }) => {\n  return <li style={style}>{item.name}</li>;\n});","looks_reasonable_because":["memo","Stable item","Theme prop"],"review_summary":"Inline style object new each render = memo defeated.","issues_found":[{"issue_number":1,"severity":"major","location":"inline style","title":"memo defeated","explanation":"{background: theme.bg} new each parent render.","root_cause":"Inline","fix":"useMemo style or use className","verification":"Profiler"}],"issues_that_arent_issues":"memo concept OK.","broader_pattern":"Inline objects/arrays/functions defeat memo.","fixed_code":"function CardList({ items, theme }: Props) {\n  const cardStyle = useMemo(() => ({ background: theme.bg }), [theme.bg]);\n  return (\n    <ul>\n      {items.map(item => (\n        <CardMemo key={item.id} item={item} style={cardStyle} />\n      ))}\n    </ul>\n  );\n}\n// Better - className with CSS variable:\nfunction CardList({ items }: Props) {\n  return (\n    <ul>\n      {items.map(item => (\n        <CardMemo key={item.id} item={item} />\n      ))}\n    </ul>\n  );\n}\nconst CardMemo = memo(({ item }: Props) => (\n  <li className=\"bg-[var(--card-bg)]\">{item.name}</li>\n));\n// CSS variable set higher up","what_makes_this_review_senior":"Object stability for memo; CSS variables as alternative."}
{"id":"review-167","category":"memory_leaks_in_hooks","difficulty":"expert","scenario":"Subscribing to event emitter.","submitter_context":"PR: 'Listen to socket.'","code_under_review":"function useSocketData(channel: string) {\n  const [data, setData] = useState(null);\n  useEffect(() => {\n    socket.on(channel, setData);\n  }, [channel]);\n  return data;\n}","looks_reasonable_because":["Subscribe","Returns data","Simple"],"review_summary":"No cleanup = accumulates handlers.","issues_found":[{"issue_number":1,"severity":"critical","location":"no cleanup","title":"Handler leak","explanation":"Channel changes/unmount = handlers accumulate.","root_cause":"Missing socket.off","fix":"return socket.off","verification":"Channel switch"}],"issues_that_arent_issues":"Subscribe pattern OK.","broader_pattern":"Always cleanup subscriptions.","fixed_code":"function useSocketData<T>(channel: string) {\n  const [data, setData] = useState<T | null>(null);\n  useEffect(() => {\n    const handler = (d: T) => setData(d);\n    socket.on(channel, handler);\n    return () => socket.off(channel, handler);\n  }, [channel]);\n  return data;\n}","what_makes_this_review_senior":"Subscription cleanup discipline."}
{"id":"review-168","category":"race_conditions_in_async","difficulty":"expert","scenario":"useTransition update.","submitter_context":"PR: 'Filter list with transition.'","code_under_review":"function FilterableList({ items }: Props) {\n  const [query, setQuery] = useState('');\n  const [pending, startTransition] = useTransition();\n  \n  const onChange = (q: string) => {\n    startTransition(() => {\n      setQuery(q);\n    });\n  };\n  \n  return (\n    <>\n      <input onChange={(e) => onChange(e.target.value)} />\n      <List items={items.filter(i => i.name.includes(query))} />\n    </>\n  );\n}","looks_reasonable_because":["useTransition","Filter","Pending"],"review_summary":"Input itself not updated immediately. Input is uncontrolled but should be controlled.","issues_found":[{"issue_number":1,"severity":"major","location":"setQuery in transition","title":"Input lag","explanation":"setQuery wrapped in transition = input itself updates slow. Input feels laggy.","root_cause":"Transition for input value","fix":"Split: input state urgent, filter state non-urgent","verification":"Type rapidly"}],"issues_that_arent_issues":"Transition concept OK.","broader_pattern":"useTransition for derived heavy work, not input state itself.","fixed_code":"function FilterableList({ items }: Props) {\n  const [query, setQuery] = useState('');  // urgent\n  const [filtered, setFiltered] = useState(items);\n  const [pending, startTransition] = useTransition();\n  \n  const onChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    setQuery(e.target.value);  // urgent - input responsive\n    startTransition(() => {\n      setFiltered(items.filter(i => i.name.includes(e.target.value)));  // non-urgent\n    });\n  };\n  \n  return (\n    <>\n      <input value={query} onChange={onChange} />\n      {pending && <Spinner />}\n      <List items={filtered} />\n    </>\n  );\n}","what_makes_this_review_senior":"Transition for non-urgent work; input state urgent."}
{"id":"review-169","category":"typescript_false_confidence","difficulty":"expert","scenario":"Type narrowing.","submitter_context":"PR: 'Handle response.'","code_under_review":"interface Response { data: any; error?: string; }\n\nfunction handle(r: Response) {\n  if (r.error) {\n    showError(r.error);\n  } else {\n    showData(r.data);  // typed as any\n  }\n}","looks_reasonable_because":["Error check","Narrowing","Works"],"review_summary":"data is any. Discriminated union would type-safe both branches.","issues_found":[{"issue_number":1,"severity":"major","location":"data: any","title":"any leaks","explanation":"showData(r.data) accepts anything. No type safety.","root_cause":"any","fix":"Generic + discriminated union","verification":"Pass wrong shape"}],"issues_that_arent_issues":"Error checking OK.","broader_pattern":"Discriminated union for response types.","fixed_code":"type Response<T> =\n  | { ok: true; data: T }\n  | { ok: false; error: string };\n\nfunction handle<T>(r: Response<T>, onData: (data: T) => void, onError: (msg: string) => void) {\n  if (!r.ok) {\n    onError(r.error);\n  } else {\n    onData(r.data);  // typed T\n  }\n}","what_makes_this_review_senior":"Discriminated union narrows both branches."}
{"id":"review-170","category":"accessibility_violations","difficulty":"expert","scenario":"Click handler on div.","submitter_context":"PR: 'Card with click action.'","code_under_review":"function Card({ title, onClick }: { title: string; onClick: () => void }) {\n  return (\n    <div onClick={onClick} className=\"cursor-pointer\">\n      {title}\n    </div>\n  );\n}","looks_reasonable_because":["Click","Cursor","Works"],"review_summary":"Div with click = not keyboard accessible, no role, no focus.","issues_found":[{"issue_number":1,"severity":"critical","location":"<div onClick>","title":"Not keyboard accessible","explanation":"Tab skips, Enter doesn't trigger.","root_cause":"Wrong element","fix":"<button> or <a>","verification":"Keyboard"}],"issues_that_arent_issues":"Card visual OK.","broader_pattern":"Interactive elements: <button> for actions, <a> for navigation.","fixed_code":"function Card({ title, onClick }: { title: string; onClick: () => void }) {\n  return (\n    <button\n      type=\"button\"\n      onClick={onClick}\n      className=\"text-left w-full cursor-pointer hover:bg-gray-50\"\n    >\n      {title}\n    </button>\n  );\n}","what_makes_this_review_senior":"div onClick = not keyboard accessible; button as default."}
{"id":"review-171","category":"state_management_misuse","difficulty":"expert","scenario":"Storing JSX in state.","submitter_context":"PR: 'Notification queue.'","code_under_review":"function App() {\n  const [notifications, setNotifications] = useState<ReactNode[]>([]);\n  \n  const showNotification = (jsx: ReactNode) => {\n    setNotifications(n => [...n, jsx]);\n  };\n  \n  return <>{notifications.map((n, i) => <div key={i}>{n}</div>)}</>;\n}","looks_reasonable_because":["Notification queue","JSX","Works"],"review_summary":"JSX in state = stale closures, serialization issues, debugging hard.","issues_found":[{"issue_number":1,"severity":"major","location":"ReactNode in state","title":"Stale closures","explanation":"JSX captures closure at time of creation. Later renders use stale data.","root_cause":"JSX in state","fix":"Data in state, JSX in render","verification":"Reference state in JSX"},{"issue_number":2,"severity":"minor","location":"key={i}","title":"Index keys for queue","explanation":"Removing from middle messes up keys.","root_cause":"Index","fix":"Stable id","verification":"Remove from middle"}],"issues_that_arent_issues":"Queue pattern OK.","broader_pattern":"Store data, render JSX.","fixed_code":"type Notification = { id: string; type: 'info' | 'error'; message: string };\n\nfunction App() {\n  const [notifications, setNotifications] = useState<Notification[]>([]);\n  \n  const showNotification = (type: Notification['type'], message: string) => {\n    setNotifications(n => [...n, { id: nanoid(), type, message }]);\n  };\n  \n  return (\n    <>\n      {notifications.map(n => (\n        <div key={n.id} className={n.type === 'error' ? 'bg-red-100' : 'bg-blue-100'}>\n          {n.message}\n        </div>\n      ))}\n    </>\n  );\n}","what_makes_this_review_senior":"Data over JSX in state; stable IDs."}
{"id":"review-172","category":"form_handling_disasters","difficulty":"expert","scenario":"Submit on Enter.","submitter_context":"PR: 'Single-input form.'","code_under_review":"function QuickSearch() {\n  const [q, setQ] = useState('');\n  return (\n    <input\n      value={q}\n      onChange={(e) => setQ(e.target.value)}\n      onKeyDown={(e) => e.key === 'Enter' && search(q)}\n    />\n  );\n}","looks_reasonable_because":["Single input","Enter to submit","Works"],"review_summary":"No form. No label. IME issues.","issues_found":[{"issue_number":1,"severity":"major","location":"No <form>","title":"Browser doesn't recognize","explanation":"<form> handles Enter natively + provides submit semantics.","root_cause":"Missing form","fix":"<form>","verification":"Browser test"},{"issue_number":2,"severity":"major","location":"IME","title":"Enter during IME compose","explanation":"Japanese/Chinese input: Enter confirms char.","root_cause":"No isComposing check","fix":"isComposing","verification":"Japanese IME"},{"issue_number":3,"severity":"minor","location":"No label","title":"a11y","explanation":"SR","root_cause":"Missing","fix":"<label> or aria-label","verification":"SR"}],"issues_that_arent_issues":"Search concept OK.","broader_pattern":"Forms over manual Enter handling.","fixed_code":"function QuickSearch() {\n  const [q, setQ] = useState('');\n  return (\n    <form onSubmit={(e) => { e.preventDefault(); search(q); }}>\n      <label htmlFor=\"search-input\" className=\"sr-only\">Search</label>\n      <input\n        id=\"search-input\"\n        type=\"search\"\n        value={q}\n        onChange={(e) => setQ(e.target.value)}\n      />\n    </form>\n  );\n  // <form> handles Enter + IME naturally\n}","what_makes_this_review_senior":"<form> for native semantics; IME consideration."}
{"id":"review-173","category":"animation_performance_hits","difficulty":"expert","scenario":"Smooth scroll to top.","submitter_context":"PR: 'Scroll to top button.'","code_under_require":"function ScrollToTop() {\n  const scrollToTop = () => {\n    const start = window.scrollY;\n    const duration = 500;\n    const startTime = performance.now();\n    function animate() {\n      const elapsed = performance.now() - startTime;\n      const progress = Math.min(elapsed / duration, 1);\n      window.scrollTo(0, start * (1 - progress));\n      if (progress < 1) requestAnimationFrame(animate);\n    }\n    requestAnimationFrame(animate);\n  };\n  return <button onClick={scrollToTop}>Top</button>;\n}","code_under_review":"function ScrollToTop() {\n  const scrollToTop = () => {\n    const start = window.scrollY;\n    const duration = 500;\n    const startTime = performance.now();\n    function animate() {\n      const elapsed = performance.now() - startTime;\n      const progress = Math.min(elapsed / duration, 1);\n      window.scrollTo(0, start * (1 - progress));\n      if (progress < 1) requestAnimationFrame(animate);\n    }\n    requestAnimationFrame(animate);\n  };\n  return <button onClick={scrollToTop}>Top</button>;\n}","looks_reasonable_because":["rAF","Smooth","Works"],"review_summary":"Native window.scrollTo({behavior: 'smooth'}) does this. No need to roll own.","issues_found":[{"issue_number":1,"severity":"minor","location":"Custom animation","title":"Reinventing scroll behavior","explanation":"Native scrollTo with behavior: 'smooth' is one line. Plus respects prefers-reduced-motion.","root_cause":"DIY","fix":"Native","verification":"None"}],"issues_that_arent_issues":"Functionality OK.","broader_pattern":"Use native APIs when available.","fixed_code":"function ScrollToTop() {\n  const scrollToTop = () => {\n    window.scrollTo({ top: 0, behavior: 'smooth' });\n    // 'smooth' respects prefers-reduced-motion automatically\n  };\n  return <button onClick={scrollToTop}>Top</button>;\n}","what_makes_this_review_senior":"Native scrollTo with smooth; respects motion preferences."}
{"id":"review-174","category":"bundle_size_bloat","difficulty":"expert","scenario":"PDF rendering.","submitter_context":"PR: 'Show PDFs.'","code_under_review":"import * as pdfjs from 'pdfjs-dist';\n\nfunction PdfViewer({ url }: { url: string }) {\n  useEffect(() => {\n    // load and render PDF\n  }, [url]);\n  return <canvas />;\n}","looks_reasonable_because":["PDF lib","Renders PDFs","Works"],"review_summary":"pdfjs-dist is ~1MB. Loaded on every page even if no PDF.","issues_found":[{"issue_number":1,"severity":"critical","location":"static import","title":"1MB always shipped","explanation":"Pages without PDFs still pay the cost.","root_cause":"Static","fix":"Dynamic import","verification":"Bundle"}],"issues_that_arent_issues":"PDF rendering needs lib.","broader_pattern":"Heavy libs = lazy load on demand.","fixed_code":"import { lazy, Suspense } from 'react';\n\nconst PdfViewerInner = lazy(() => import('./PdfViewerInner'));\n\nexport function PdfViewer({ url }: { url: string }) {\n  return (\n    <Suspense fallback={<div>Loading PDF viewer...</div>}>\n      <PdfViewerInner url={url} />\n    </Suspense>\n  );\n}\n\n// PdfViewerInner.tsx (lazy chunk)\nimport * as pdfjs from 'pdfjs-dist';\n// ... rest","what_makes_this_review_senior":"Heavy deps lazy-loaded; Suspense wrapper."}
{"id":"review-175","category":"production_only_bugs","difficulty":"expert","scenario":"Time-based conditional.","submitter_context":"PR: 'Show countdown.'","code_under_review":"function Countdown({ until }: { until: Date }) {\n  const remaining = until.getTime() - Date.now();\n  return <div>{Math.max(0, Math.floor(remaining / 1000))}s</div>;\n}","looks_reasonable_because":["Time calculation","Works once","Math.max for negative"],"review_summary":"No update! Renders once. Date.now() in render = hydration mismatch on SSR.","issues_found":[{"issue_number":1,"severity":"critical","location":"No update","title":"Static","explanation":"Date.now() in render doesn't update. Countdown stuck.","root_cause":"No state","fix":"useState + setInterval","verification":"Wait, observe"},{"issue_number":2,"severity":"critical","location":"Date.now() in render","title":"SSR mismatch","explanation":"Server time != client time.","root_cause":"Date in render","fix":"useState post-mount","verification":"SSR"}],"issues_that_arent_issues":"Math.max OK.","broader_pattern":"Time-dependent UI: state + interval; SSR-safe.","fixed_code":"function Countdown({ until }: { until: Date }) {\n  const [remaining, setRemaining] = useState<number | null>(null);\n  \n  useEffect(() => {\n    const update = () => setRemaining(Math.max(0, until.getTime() - Date.now()));\n    update();\n    const id = setInterval(update, 1000);\n    return () => clearInterval(id);\n  }, [until]);\n  \n  if (remaining === null) return <div>—</div>;\n  return <div>{Math.floor(remaining / 1000)}s</div>;\n}","what_makes_this_review_senior":"Live UI = state + interval; SSR-safe via mount-then-set."}
